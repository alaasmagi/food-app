# Base URL of the backend API, under the same parent domain as this app.
# All API calls attach a Keycloak-issued bearer token; no cookies are sent.
VITE_API_BASE_URL=https://api.<domain>

# Keycloak (direct-to-Keycloak auth via keycloak-js, Authorization Code + PKCE).
# VITE_KEYCLOAK_URL is the authority root (no /realms/... suffix).
# The realm must define a PUBLIC client (no secret) for this web app with:
#   - Standard flow enabled, PKCE (S256) required
#   - Valid redirect URIs: https://app.<domain>/* (and http://localhost:5173/* for dev)
#   - Valid post-logout redirect URIs: https://app.<domain>/login (+ localhost for dev)
#   - Web origins: https://app.<domain> (+ http://localhost:5173 for dev)
#   - Silent check-sso redirect URI: https://app.<domain>/silent-check-sso.html
VITE_KEYCLOAK_URL=https://identity.<domain>
VITE_KEYCLOAK_REALM=food-app
VITE_KEYCLOAK_CLIENT_ID=food-app-web
