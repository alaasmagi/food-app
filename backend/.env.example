# Copy this file to .env for local development and fill in real values.

# Application HTTP port inside container/process (used to build ASPNETCORE_URLS when not set explicitly).
APP_PORT=8080

# Platform-provided port fallback used when APP_PORT is not set.
PORT=8080

# Optional explicit ASP.NET Core binding. When set, this overrides APP_PORT/PORT-derived binding.
ASPNETCORE_URLS=http://+:8080

# Optional host port mapping for docker compose deployments.
HOST_PORT=8080

# PostgreSQL connection used by AppDbContext.
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=app;Username=app_user;Password=change-me;Search Path=app

# Redis cache connection and default cache behavior.
REDIS_CONNECTION_STRING=localhost:6379
CACHE_KEY_PREFIX=app-service
CACHE_DEFAULT_ABSOLUTE_EXPIRATION_SECONDS=300

# RabbitMQ connection, publishing exchange, consumer queue, and topic bindings.
RABBITMQ_URI=amqps://username:password@rabbitmq.example.com:5671/vhost
RABBITMQ_QUEUE=app-service
RABBITMQ_EXCHANGE=app.events
RABBITMQ_CONSUMER_ROUTING_KEYS=user.*
APP_EVENT_SOURCE=app-service

# Glitchtip/Sentry-compatible error and log reporting.
GLITCHTIP_DSN=https://examplePublicKey@glitchtip.example.com/1
GLITCHTIP_RELEASE=app-service

# API rate limiting.
RATE_LIMIT_PERMIT_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_QUEUE_LIMIT=0

# Keycloak authentication.
KEYCLOAK_AUTHORITY=https://identity.alaasmagi.dev/realms/app-service
KEYCLOAK_CLIENT_ID=app-service
KEYCLOAK_CLIENT_SECRET=change-me

# Exact origin of the Vue frontend, used for the credentialed CORS policy on the /account/* endpoints.
FRONTEND_ORIGIN=https://app.alaasmagi.dev
