@model DiningEnvironmentDto
@{
    ViewData["Title"] = "Create dining environment";
}

<h1 class="h3 mb-3">Create dining environment</h1>

<form asp-action="Create" class="col-lg-8">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Owner</label>
        <select name="OwnerId" asp-items="ViewBag.Owners" class="form-select">
            <option value="">— Select owner —</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
