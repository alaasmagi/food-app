@model DiningEnvironmentDto
@{
    ViewData["Title"] = "Dining environment details";
}

<h1 class="h3 mb-3">@Model.Name</h1>

<dl class="row col-lg-8">
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
</dl>

<a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a class="btn btn-link" asp-action="Index">Back to list</a>
