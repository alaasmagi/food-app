@model FavouriteDto
@{
    ViewData["Title"] = "Edit favourite";
}

<h1 class="h3 mb-3">Edit favourite</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" class="col-lg-8">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ConcurrencyToken" />

    <div class="mb-3">
        <label asp-for="RestaurantId" class="form-label">Restaurant</label>
        <select asp-for="RestaurantId" asp-items="ViewBag.Restaurants" class="form-select"></select>
        <span asp-validation-for="RestaurantId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Rating" class="form-label"></label>
        <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Note" class="form-label"></label>
        <textarea asp-for="Note" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
