@model UserWheelDto
@{
    ViewData["Title"] = "Edit user wheel";
}

<h1 class="h3 mb-3">Edit user wheel</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" class="col-lg-8">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ConcurrencyToken" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Restaurant names (one per line)</label>
        <textarea name="RestaurantNamesText" class="form-control" rows="4">@string.Join("\n", Model.RestaurantNames)</textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsPublic" class="form-check-input" />
        <label asp-for="IsPublic" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
