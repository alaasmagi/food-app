@model EnvironmentRestaurantDto
@{
    ViewData["Title"] = "Create environment restaurant";
}

<h1 class="h3 mb-3">Create environment restaurant</h1>

<form asp-action="Create" class="col-lg-8">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Owner</label>
        <select name="OwnerId" asp-items="ViewBag.Owners" class="form-select">
            <option value="">— Select owner —</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="EnvironmentId" class="form-label">Environment</label>
        <select asp-for="EnvironmentId" asp-items="ViewBag.Environments" class="form-select"></select>
        <span asp-validation-for="EnvironmentId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="RestaurantId" class="form-label">Restaurant</label>
        <select asp-for="RestaurantId" asp-items="ViewBag.Restaurants" class="form-select"></select>
        <span asp-validation-for="RestaurantId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
